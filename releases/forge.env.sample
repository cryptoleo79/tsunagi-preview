# TSUNAGI forge.env — SAMPLE (no real values; fill in your own).
# Copy to $TSUNAGI_HOME/forge.env  (default: ~/tsunagi-home/forge.env)
# Network is chosen on the command line:  ./tsunagi-node run --net preview

# --- home ---
export TSUNAGI_HOME="$HOME/tsunagi-home"

# --- mode: OBSERVE by default (safe for evaluation) ---
export TSUNAGI_FORGE_ENABLE=0          # 0 = observe/sync only; 1 = produce (needs keys below)

# --- block-production keys (REQUIRED only when TSUNAGI_FORGE_ENABLE=1) ---
# Generate these yourself with cardano-cli. Keep the COLD key OFFLINE. Never commit real keys.
export TSUNAGI_VRF_SKEY_PATH="$TSUNAGI_HOME/keys/vrf.skey"
export TSUNAGI_KES_SKEY_PATH="$TSUNAGI_HOME/keys/kes.skey"
export TSUNAGI_OPCERT_PATH="$TSUNAGI_HOME/keys/node.cert"
export TSUNAGI_KES_START_PERIOD="<your_kes_start_period>"
export TSUNAGI_COLD_VK_HEX="<your_cold_vkey_hex>"
export TSUNAGI_OPCERT_SIGMA_HEX="<your_precomputed_opcert_sigma_hex>"

# NEVER commit this file once it contains real key paths/values.
